# =============================================================================
# SERVIDOR SOC - Configuracion de Ejemplo
# =============================================================================
# Copia este archivo a .env y ajusta los valores segun tu entorno.
#
# === GENERAR SECRETOS SEGUROS ===
# Ejecuta en terminal:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Copia el output como valor para las variables secretas.
#
# === SEGURIDAD DE COMUNICACIONES ===
# Para habilitar request signing, configurar:
#   AGENT_API_SECRET=<secret-generado>
#   DASHBOARD_API_SECRET=<secret-generado>
# Ambos secretos deben coincidir con los del cliente.
#
# -----------------------------------------------------------------------------
# CONFIGURACION DEL SERVIDOR
# -----------------------------------------------------------------------------
# Host y puerto donde escuchara el servidor
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# -----------------------------------------------------------------------------
# SEGURIDAD SSL/TLS
# -----------------------------------------------------------------------------
# Habilitar HTTPS (requiere certificados)
ENABLE_SSL=true

# Ruta al certificado SSL (generado con letsencrypt o auto-firmado)
SSL_CERT_FILE=server.crt

# Ruta a la clave privada SSL
SSL_KEY_FILE=server.key

# -----------------------------------------------------------------------------
# AUTENTICACION DE AGENTES
# -----------------------------------------------------------------------------
# Clave API para autenticar agentes (debe ser igual que en agent/.env)
AGENT_API_KEY=changeme

# -----------------------------------------------------------------------------
# DASHBOARD API (endpoints de solo lectura)
# -----------------------------------------------------------------------------
# Habilitar autenticacion para dashboard
DASHBOARD_AUTH_ENABLED=true

# Usuario para acceder al dashboard via API
DASHBOARD_USERNAME=admin

# Contrasena (usar DASHBOARD_PASSWORD_HASH en produccion)
DASHBOARD_PASSWORD=changeme

# Hash bcrypt de la contrasena (generar con: python -c "import bcrypt; print(bcrypt.hashpw(b'tupass', bcrypt.gensalt()).decode())")
# DASHBOARD_PASSWORD_HASH=$2b$12$...

# API Key para acceso programatico al dashboard
# DASHBOARD_API_KEY=your-api-key

# API Secret para firmar requests (HMAC-SHA256)
# Usar: python -c "import secrets; print(secrets.token_urlsafe(32))"
# DASHBOARD_API_SECRET=your-secret-key-min-32-chars

# -----------------------------------------------------------------------------
# AGENT API (endpoints de agentes)
# -----------------------------------------------------------------------------
# Secret para firmar requests de agentes
# Usar: python -c "import secrets; print(secrets.token_urlsafe(32))"
# AGENT_API_SECRET=your-secret-key-min-32-chars

# TTL para nonces (previene replay attacks) en segundos
NONCE_TTL_SECONDS=300

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
# Numero maximo de peticiones por minuto por IP (agentes)
RATE_LIMIT_RPM=60

# Rate limit burst allowance
RATE_LIMIT_BURST=20

# Maximo de requests concurrentes
MAX_CONCURRENT_REQUESTS=50

# Tamano maximo de request en KB
MAX_REQUEST_SIZE_KB=64

# Rate limit para dashboard API
DASHBOARD_RATE_LIMIT=100
DASHBOARD_RATE_LIMIT_BURST=20

# -----------------------------------------------------------------------------
# THREAT DETECTION
# -----------------------------------------------------------------------------
# Intentos de auth fallidos antes de bloquear IP
THREAT_THRESHOLD_AUTH=5

# Violaciones de rate limit antes de bloquear
THREAT_THRESHOLD_RATE=10

# Ventana de tiempo para contar violaciones (minutos)
THREAT_WINDOW_MINUTES=15

# -----------------------------------------------------------------------------
# DEBUG
# -----------------------------------------------------------------------------
# Activar modo debug de Flask (reloader, mensajes detallados)
# ADVERTENCIA: No usar en produccion!
# Valores: true, false
FLASK_DEBUG=false

# -----------------------------------------------------------------------------
# BASE DE DATOS
# -----------------------------------------------------------------------------
# Ruta al archivo de base de datos SQLite
# Por defecto: server/database.db (relativo al proyecto)
# Ejemplos:
#   DB_PATH=server/database.db       (relativo al proyecto)
#   DB_PATH=C:/data/soc.db           (Windows)
#   DB_PATH=/var/lib/soc/database.db (Linux)
DB_PATH=server/database.db

# -----------------------------------------------------------------------------
# EVENT QUEUE (procesamiento asincrono)
# -----------------------------------------------------------------------------
# Tamano de la cola de eventos
EVENT_QUEUE_SIZE=1000

# Tamano de batch para procesamiento
EVENT_BATCH_SIZE=50

# Timeout para flush de batch (segundos)
EVENT_BATCH_TIMEOUT=5

# -----------------------------------------------------------------------------
# ALERTAS
# -----------------------------------------------------------------------------
# Umbral de riesgo para enviar alertas automaticas
# (10 = MEDIUM, 30 = HIGH, 50 = CRITICAL)
ALERT_THRESHOLD_RISK=10

# -----------------------------------------------------------------------------
# CIRCUIT BREAKER (resistencia a fallos)
# -----------------------------------------------------------------------------
# Numero de fallos antes de abrir el circuit breaker
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5

# Segundos antes de intentar recover
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60

# -----------------------------------------------------------------------------
# TELEGRAM (opcional)
# -----------------------------------------------------------------------------
# Token del bot de Telegram (obtenido de @BotFather)
TELEGRAM_TOKEN=

# Chat ID donde se enviarian las alertas
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
# Archivo para logs de auditoria
AUDIT_LOG_FILE=audit.log

# Archivo para IPs bloqueadas
BLOCKED_IPS_FILE=blocked_ips.txt

# -----------------------------------------------------------------------------
# DEDUPLICACION Y LATE EVENTS
# -----------------------------------------------------------------------------
# Ventana de deduplicacion en minutos
# Un evento se considera duplicado si ya existe dentro de esta ventana
# Valor recomendado: 1-5 minutos para alto volumen
DEDUP_WINDOW_MINUTES=2

# Maximo tiempo en horas para aceptar eventos historicos
# Eventos con timestamp mayor a esto seran ignorados
MAX_EVENT_AGE_HOURS=24

# Habilitar re-correlacion periodica
ENABLE_RECORRELATION=true

# Intervalo de re-correlacion en horas
RECORRELATION_INTERVAL_HOURS=24