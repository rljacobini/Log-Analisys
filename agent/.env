# =============================================================================
# AGENTE SOC - Configuracion del Agente
# =============================================================================

# Identificacion del agente
AGENT_ID=agent-srv-01
TARGET_HOST=192.168.1.10
TARGET_SERVICE=ssh

# Fuente de log a monitorear
SOURCE=auth.log
AUTH_LOG_FILE=data/auth.log

# Directorios permitidos para archivos de log (separados por coma)
# Por defecto se usa <proyecto>/data
# Ejemplos:
#   ALLOWED_LOG_DIRS=data                    (relativo al proyecto)
#   ALLOWED_LOG_DIRS=C:/logs,D:/logs2        (Windows, rutas absolutas)
#   ALLOWED_LOG_DIRS=/var/log,/var/log/auth  (Linux, rutas absolutas)
ALLOWED_LOG_DIRS=

# Intervalo de monitoreo en segundos
AGENT_INTERVAL=10

# Conexion al servidor
SERVER_URL=https://127.0.0.1:5000/log
USE_SSL=true
VERIFY_SSL=false
X_API_KEY=_OsuADwL45nXK2T3CAXY6F4xefz6StObNG2A00G0ZWM

# Thresholds de deteccion
BRUTE_FORCE_THRESHOLD=5
BRUTE_FORCE_WINDOW=60
RISK_CRITICAL=50
RISK_HIGH=30
RISK_MEDIUM=15

# Cooldown de envio (segundos)
SEND_COOLDOWN_DEFAULT=15
SEND_COOLDOWN_CRITICAL=0
SEND_COOLDOWN_HIGH=5

# Timeout de peticion HTTP (segundos)
AGENT_TIMEOUT=10

# Directorio para estado del agente (opcional)
STATE_DIR=

# Nivel de logging
AGENT_LOG_LEVEL=INFO