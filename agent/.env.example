# =============================================================================
# AGENTE SOC - Configuracion de Ejemplo
# =============================================================================
# Copia este archivo a .env y ajusta los valores segun tu entorno.
#
# === GENERAR SECRETOS SEGUROS ===
# Generar secret para request signing:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# === SEGURIDAD (RECOMENDADO PARA PRODUCCION) ===
# Para habilitar request signing:
#   1. En server/.env: AGENT_API_SECRET=<secret-generado>
#   2. En agente/.env: X_API_KEY_SECRET=<mismo-secret>
#
# Esto habilita:
#   - X-Request-ID: Nonce unico para cada request
#   - X-Request-Timestamp: Timestamp para evitar replay
#   - X-Request-Signature: HMAC-SHA256 de request y response
#
# -----------------------------------------------------------------------------
# IDENTIFICACION DEL AGENTE
# -----------------------------------------------------------------------------
# Identificador unico del agente
AGENT_ID=agent-srv-01

# IP del host donde esta este agente
TARGET_HOST=192.168.1.100

# Servicio que monitorea (ssh, http, ftp, etc.)
TARGET_SERVICE=ssh

# -----------------------------------------------------------------------------
# FUENTE DE LOG
# -----------------------------------------------------------------------------
# Tipo de log a monitorear (auth.log, secure, etc.)
SOURCE=auth.log

# Ruta al archivo de log (relativa al proyecto o absoluta)
AUTH_LOG_FILE=data/auth.log

# Directorios permitidos para archivos de log (separados por coma)
# Por defecto: <proyecto>/data
# Ejemplos:
#   ALLOWED_LOG_DIRS=data                    (relativo al proyecto)
#   ALLOWED_LOG_DIRS=C:/logs,D:/backup/logs  (Windows, rutas absolutas)
#   ALLOWED_LOG_DIRS=/var/log,/var/log/auth  (Linux, rutas absolutas)
ALLOWED_LOG_DIRS=

# -----------------------------------------------------------------------------
# INTERVALO DE MONITOREO
# -----------------------------------------------------------------------------
# Segundos entre cada lectura del archivo de log
AGENT_INTERVAL=10

# -----------------------------------------------------------------------------
# CONEXION AL SERVIDOR
# -----------------------------------------------------------------------------
# URL del servidor SOC (https recomendado para produccion)
SERVER_URL=https://tu-servidor.com/log

# URL para modo batch (opcional, se deriva de SERVER_URL)
# BATCH_URL=https://tu-servidor.com/log/batch

# Habilitar SSL/TLS para conexion segura
USE_SSL=true

# Verificar certificado del servidor (false solo para pruebas con auto-firmados)
VERIFY_SSL=true

# Clave API para autenticar con el servidor
X_API_KEY=changeme

# Secret para firmar requests (HMAC-SHA256)
# Debe coincidir con AGENT_API_SECRET en server/.env
# Habilita request signing para mayor seguridad
X_API_KEY_SECRET=

# -----------------------------------------------------------------------------
# BATCH MODE (reduccion de carga en servidor)
# -----------------------------------------------------------------------------
# Habilitar modo batch (agrupa eventos antes de enviar)
USE_BATCH_MODE=true

# Numero maximo de eventos por batch
BATCH_SIZE=20

# Timeout para enviar batch sin actividad (segundos)
BATCH_TIMEOUT=30

# Tamano de cola de reintentos
BATCH_RETRY_QUEUE_SIZE=100

# Maximo de reintentos por evento
MAX_BATCH_RETRIES=3

# Delay inicial para reintentos (segundos)
INITIAL_RETRY_DELAY=5

# Delay maximo para reintentos (segundos)
MAX_RETRY_DELAY=120

# Maximo de fallos consecutivos antes de pausar
MAX_CONSECUTIVE_FAILURES=10

# Multiplicador para exponential backoff
BACKOFF_MULTIPLIER=2.0

# -----------------------------------------------------------------------------
# THRESHOLDS DE DETECCION
# -----------------------------------------------------------------------------
# Numero de intentos fallidos para detectar brute force
BRUTE_FORCE_THRESHOLD=5

# Ventana de tiempo para detectar intentos (segundos)
BRUTE_FORCE_WINDOW=60

# Niveles de riesgo para severidad
RISK_CRITICAL=50
RISK_HIGH=30
RISK_MEDIUM=15

# Riesgo especial para login exitoso despues de brute force (overridden a 100+)
RISK_LOGIN_AFTER_BRUTEFORCE=100

# -----------------------------------------------------------------------------
# COOLDOWN (evita spam de alertas)
# -----------------------------------------------------------------------------
# Segundos minimos entre alertas del mismo tipo
# 0 = sin limite (enviar siempre)
SEND_COOLDOWN_DEFAULT=15
SEND_COOLDOWN_CRITICAL=0
SEND_COOLDOWN_HIGH=5

# -----------------------------------------------------------------------------
# CONFIGURACION DE RED
# -----------------------------------------------------------------------------
# Timeout para peticiones HTTP (segundos)
AGENT_TIMEOUT=10

# -----------------------------------------------------------------------------
# PERSISTENCIA DE ESTADO
# -----------------------------------------------------------------------------
# Directorio donde se guarda el estado del agente
# Por defecto: misma carpeta del agente
# Ejemplos:
#   STATE_DIR=./state        (relativo a la carpeta del agente)
#   STATE_DIR=C:/data/agent  (ruta absoluta en Windows)
#   STATE_DIR=/var/lib/soc   (ruta absoluta en Linux)
STATE_DIR=

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
# Opciones: DEBUG, INFO, WARNING, ERROR, CRITICAL
AGENT_LOG_LEVEL=INFO