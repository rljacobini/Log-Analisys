# =============================================================================
# AGENTE SOC - Configuracion del WEB Agente
# =============================================================================

# -----------------------------------------------------------------------------
# IDENTIFICACION DEL AGENTE
# -----------------------------------------------------------------------------
WEB_AGENT_ID=web-srv-01

# IP del host donde esta este servidor web
WEB_TARGET_HOST=192.168.1.20

# Servicio
WEB_TARGET_SERVICE=http

# Tipo de fuente (apache, nginx)
WEB_SOURCE=apache

# -----------------------------------------------------------------------------
# FUENTE DE LOG
# -----------------------------------------------------------------------------
# Ruta al archivo de access log (relativa al proyecto o absoluta)
# Ejemplos:
#   WEB_LOG_FILE=data/web_access.log     (relativo al proyecto)
#   WEB_LOG_FILE=C:/logs/apache/access.log  (Windows)
#   WEB_LOG_FILE=/var/log/apache2/access.log  (Linux)
WEB_LOG_FILE=

# -----------------------------------------------------------------------------
# CONEXION AL SERVIDOR SOC
# -----------------------------------------------------------------------------
WEB_SERVER_URL=https://127.0.0.1:5000/log

# URL para modo batch (opcional, se deriva de SERVER_URL)
# WEB_BATCH_URL=https://tu-servidor.com/log/batch

# Clave API para autenticar con el servidor
WEB_API_KEY=_OsuADwL45nXK2T3CAXY6F4xefz6StObNG2A00G0ZWM


# Secret para firmar requests (HMAC-SHA256)
# Debe coincidir con AGENT_API_SECRET en server/.env
# Habilita request signing para mayor seguridad
WEB_API_SECRET=

# -----------------------------------------------------------------------------
# SSL/TLS
# -----------------------------------------------------------------------------
WEB_USE_SSL=true
WEB_VERIFY_SSL=true

# -----------------------------------------------------------------------------
# COOLDOWN (evita spam de alertas)
# -----------------------------------------------------------------------------
# Segundos minimos entre alertas del mismo tipo
WEB_SEND_COOLDOWN_DEFAULT=30
WEB_SEND_COOLDOWN_CRITICAL=0
WEB_SEND_COOLDOWN_HIGH=15

# -----------------------------------------------------------------------------
# INTERVALO Y BATCHING
# -----------------------------------------------------------------------------
WEB_AGENT_INTERVAL=10

# Timeout para HTTP (segundos)
WEB_REQUEST_TIMEOUT=10

WEB_USE_BATCH_MODE=true
WEB_BATCH_SIZE=20
WEB_BATCH_TIMEOUT=30

# -----------------------------------------------------------------------------
# DETECCION DE ATAQUES WEB
# -----------------------------------------------------------------------------
# Numero de requests para detectar HTTP flood
WEB_FLOOD_THRESHOLD=100

# Ventana de tiempo para flood (segundos)
WEB_FLOOD_WINDOW=60

# Numero de 404s para detectar enumeracion
WEB_SUSPICIOUS_404_THRESHOLD=10

# Ventana de tiempo para 404s (segundos)
WEB_SUSPICIOUS_404_WINDOW=300

# -----------------------------------------------------------------------------
# PERSISTENCIA DE ESTADO
# -----------------------------------------------------------------------------
WEB_STATE_DIR=./web-agent/state

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
WEB_LOG_LEVEL=INFO