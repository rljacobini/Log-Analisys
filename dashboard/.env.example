# =============================================================================
# DASHBOARD SOC - Configuracion de Ejemplo
# =============================================================================
# Copia este archivo a .env y ajusta los valores segun tu entorno.
#
# === GENERAR SECRETOS SEGUROS ===
# Generar secret para firmard requests:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# === SEGURIDAD DE COMUNICACIONES ===
# Para modo API con firmas (recomendado):
#   1. En server/.env: DASHBOARD_API_SECRET=<secret>
#   2. En dashboard/.env: DASHBOARD_API_SECRET=<mismo-secret>
#
# Certificate pinning (produccion):
#   Obtener pin: openssl x509 -in server.crt -fingerprint -sha256
#
# -----------------------------------------------------------------------------
# SERVIDOR WEB
# -----------------------------------------------------------------------------
# Host y puerto donde escuchara el dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# -----------------------------------------------------------------------------
# AUTENTICACION HTTP BASIC
# -----------------------------------------------------------------------------
# Usuario para acceder al dashboard
DASHBOARD_USERNAME=admin

# Contrasena para acceder al dashboard
DASHBOARD_PASSWORD=changeme

# -----------------------------------------------------------------------------
# SEGURIDAD FLASK
# -----------------------------------------------------------------------------
# Clave secreta para sesiones/cookies de Flask
# IMPORTANTE: Cambiar en produccion! Usar al menos 32 caracteres
SECRET_KEY=changeme

# -----------------------------------------------------------------------------
# API REMOTA (conectar a servidor SOC externo)
# -----------------------------------------------------------------------------
# Usar API REST en vez de acceso directo a BD
USE_REMOTE_API=false

# URL del servidor SOC (debe tener Dashboard API habilitada)
SOC_API_URL=https://soc-server:5000

# Verificar certificados SSL (set false para auto-firmados)
SOC_VERIFY_SSL=false

# -----------------------------------------------------------------------------
# SEGURIDAD API CLIENT
# -----------------------------------------------------------------------------
# API Secret para firmar requests (debe coincidir con DASHBOARD_API_SECRET del servidor)
# Solo habilita si el servidor tiene DASHBOARD_API_SECRET configurado
DASHBOARD_API_SECRET=

# Timeout para requests en segundos
API_TIMEOUT=30

# Numero maximo de reintentos
API_MAX_RETRIES=3

#Tiempo base para exponential backoff
API_RETRY_BACKOFF=1.0

# Rate limit del lado cliente (requests por minuto)
CLIENT_RATE_LIMIT=60

# TTL para nonces usados ( evita replay attacks)
NONCE_TTL_SECONDS=300

# -----------------------------------------------------------------------------
# CERTIFICATE PINNING (produccion)
# -----------------------------------------------------------------------------
# Proteccion adicional contra ataques Man-in-the-Middle (MITM).
# Evita que atacantes usen certificados validos de otras CA.
#
# Obtener fingerprint del certificado:
#   openssl x509 -in server.crt -fingerprint -sha256
#
# Ejemplo de valor:
#   CERT_PINS=sha256=AB:CD:EF:12:34:56:78:90:...
# Recomendado para: Mobile apps, datos muy sensibles
# CERT_PINS=

# -----------------------------------------------------------------------------
# BASE DE DATOS (acceso directo local)
# -----------------------------------------------------------------------------
# Ruta al archivo de base de datos SQLite (el servidor debe estar corriendo)
# Por defecto: server/database.db (relativo al proyecto)
# Ejemplos:
#   DB_PATH=server/database.db       (relativo al proyecto)
#   DB_PATH=C:/data/soc.db           (Windows)
#   DB_PATH=/var/lib/soc/database.db (Linux)
DB_PATH=server/database.db

# -----------------------------------------------------------------------------
# PAGINACION
# -----------------------------------------------------------------------------
# Numero de registros por pagina
PAGE_SIZE=50

# -----------------------------------------------------------------------------
# SSL/HTTPS (para el navegador)
# -----------------------------------------------------------------------------
# Habilitar HTTPS para el dashboard
# Valores: true, false
DASHBOARD_USE_SSL=false

# Certificado SSL (rutas relatives desde dashboard/)
# Usar los del servidor o generar nuevos en data/Cert/
DASHBOARD_CERT_FILE=../server/server.crt

# Clave privada SSL
DASHBOARD_KEY_FILE=../server/server.key

# -----------------------------------------------------------------------------
# DEBUG
# -----------------------------------------------------------------------------
# Activar modo debug de Flask (reloader, mensajes detallados)
# ADVERTENCIA: No usar en produccion!
# Valores: true, false
FLASK_DEBUG=false