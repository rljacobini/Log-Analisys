# =============================================================================
# PCAP Analyzer - Configuracion de Ejemplo
# =============================================================================
# Copia este archivo a .env y ajusta los valores segun tu entorno.
#
# -----------------------------------------------------------------------------
# IDENTIFICACION
# -----------------------------------------------------------------------------
# Identificador unico del analizador PCAP
PCAP_AGENT_ID=pcap-analyzer-01

# -----------------------------------------------------------------------------
# CONEXION AL SERVIDOR SOC
# -----------------------------------------------------------------------------
# URL del servidor SOC para enviar eventos
SERVER_URL=https://127.0.0.1:5000/log

# Clave API para autenticar con el servidor
X_API_KEY=_OsuADwL45nXK2T3CAXY6F4xefz6StObNG2A00G0ZWM

# Secret para firmar requests (HMAC-SHA256)
# Debe coincidir con AGENT_API_SECRET en server/.env
X_API_KEY_SECRET=

# Habilitar SSL/TLS
USE_SSL=true

# Verificar certificado SSL (false solo para desarrollo)
VERIFY_SSL=false

# IP Reputation Check
# Obtén tu API key gratuita en https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=de94b8354268c0e389cd80cb3efa8555a5b504e0391fe33df25186bc57edb94f7069c968dffe9aa0

# Threshold para reputación (0-100, default: 50)
IP_REPUTATION_THRESHOLD=50

# -----------------------------------------------------------------------------
# FORMATO DE ENTRADA
# -----------------------------------------------------------------------------
# Formato de entrada: auto, pcap, pcapng, zeek
INPUT_FORMAT=auto

# Directorio de logs Zeek (si INPUT_FORMAT=zeek)
# ZEEK_LOG_DIR=/var/log/zeek/current

# -----------------------------------------------------------------------------
# ANALISIS
# -----------------------------------------------------------------------------
# Habilitar analisis de flags TCP
ANALYZE_TCP_FLAGS=true

# Habilitar analisis UDP
ANALYZE_UDP=true

# Habilitar analisis ICMP
ANALYZE_ICMP=true

# Habilitar deteccion de escaneos
DETECT_SCANS=true

# Habilitar deteccion de fuerza bruta
DETECT_BRUTE_FORCE=true

# Habilitar deteccion de DoS
DETECT_DOS=true

# Habilitar deteccion MITM
DETECT_MITM=true

# Habilitar deteccion de exfiltracion
DETECT_EXFILTRATION=true

# -----------------------------------------------------------------------------
# UMBRALES DE DETECCION
# -----------------------------------------------------------------------------
# Puertos escaneados para detectar port scan
PORT_SCAN_THRESHOLD=15

# Paquetes SYN para detectar SYN flood
SYN_FLOOD_THRESHOLD=50

# Ventana de tiempo para SYN flood (segundos)
SYN_FLOOD_WINDOW=60

# Intentos para detectar fuerza bruta
BRUTE_FORCE_THRESHOLD=5

# Paquetes ICMP para detectar ICMP flood
ICMP_FLOOD_THRESHOLD=100

# Paquetes UDP para detectar UDP flood
UDP_FLOOD_THRESHOLD=100

# Queries DNS para detectar tunneling
DNS_TUNNELING_QUERY_THRESHOLD=50

# Bytes totales para detectar tunneling
DNS_TUNNELING_LENGTH_THRESHOLD=100

# Bytes para detectar exfiltracion
DATA_EXFILTRATION_THRESHOLD=10000000

# -----------------------------------------------------------------------------
# RENDIMIENTO
# -----------------------------------------------------------------------------
# Maximo de paquetes en memoria
MAX_PACKETS_MEMORY=100000

# Timeout de sesion (segundos)
SESSION_TIMEOUT=300

# -----------------------------------------------------------------------------
# OUTPUT
# -----------------------------------------------------------------------------
# Archivo de salida JSON (opcional)
# OUTPUT_FILE=results.json

# Salida detallada
VERBOSE=false

# -----------------------------------------------------------------------------
# EJEMPLOS DE USO
# -----------------------------------------------------------------------------
# Analisis basico:
#   python -m pcap.pcap_analyzer captura.pcap
#
# Con envio al servidor:
#   python -m pcap.pcap_analyzer captura.pcap --server-url https://soc:5000/log --api-key secret
#
# Formato Zeek:
#   python -m pcap.pcap_analyzer /var/log/zeek/ --format zeek
#
# Salida JSON:
#   python -m pcap.pcap_analyzer captura.pcap --output results.json
#
# Modo verbose:
#   python -m pcap.pcap_analyzer captura.pcap --verbose