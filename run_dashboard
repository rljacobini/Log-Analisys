#!/usr/bin/env python
"""Run SOC Platform Dashboard."""
import sys
import os
import ssl

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

if __name__ == "__main__":
    from dashboard.config import (
        DASHBOARD_HOST, DASHBOARD_PORT, FLASK_DEBUG, USE_REMOTE_API, DB_PATH, SOC_API_URL,
        DASHBOARD_USE_SSL, DASHBOARD_CERT_FILE, DASHBOARD_KEY_FILE
    )

    mode = "REMOTE API" if USE_REMOTE_API else "DIRECT DB"
    print(f"==================================================")
    print(f"DASHBOARD SOC - Iniciado")
    print(f"==================================================")
    print(f"  Modo: {mode}")
    if USE_REMOTE_API:
        print(f"  URL API: {SOC_API_URL}")
    else:
        print(f"  DB path: {DB_PATH}")

    ssl_context = None
    protocol = "http"
    if DASHBOARD_USE_SSL:
        if DASHBOARD_CERT_FILE and DASHBOARD_KEY_FILE:
            cert_path = os.path.abspath(DASHBOARD_CERT_FILE)
            key_path = os.path.abspath(DASHBOARD_KEY_FILE)
            
            if os.path.exists(cert_path) and os.path.exists(key_path):
                ssl_context = (cert_path, key_path)
                print(f"  SSL: Habilitado ({cert_path})")
                protocol = "https"
            else:
                print(f"  SSL: ADVERTENCIA - Certificados no encontrados")
        else:
            print(f"  SSL: ADVERTENCIA - Certificados no configurados")
    else:
        print(f"  SSL: Deshabilitado")

    print(f"  {protocol}://{DASHBOARD_HOST}:{DASHBOARD_PORT}")
    print(f"==================================================")

    from dashboard.app import app
    
    app.run(
        host=DASHBOARD_HOST,
        port=DASHBOARD_PORT,
        debug=FLASK_DEBUG,
        ssl_context=ssl_context
    )